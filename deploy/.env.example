# Copy to deploy/.env, then run `docker compose up --build` from the repo root:
#   cp deploy/.env.example deploy/.env
#
# The defaults below are enough to bring the whole stack up and sign in with the
# "demo login" button (no Google account needed). Fill in the Google/Gemini
# values only if you want real Gmail ingest.

# --- Postgres ---
# These are read by the db container AND make up DATABASE_URL below -- keep them
# in sync. Avoid special characters here, or URL-encode them in DATABASE_URL
# (e.g. "#" -> "%23", "@" -> "%40").
POSTGRES_USER=mailbox
POSTGRES_PASSWORD=mailbox
POSTGRES_DB=ai_mailbox

# --- App ---
# Anything other than dev/development/local/test/testing/ci is treated as
# production, where the app refuses to start unless API_SECRET is strong
# (>= 32 bytes, not "change_me") and the GOOGLE_* OAuth vars are all set. Keep
# this "dev" for local testing -- it also enables the passwordless demo login.
APP_ENV=dev
# Signs session tokens (HS256 JWT). Fine to leave as-is for local dev.
API_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=10080  # 7 days
# Encrypts provider OAuth tokens at rest (Fernet, urlsafe base64 32 bytes).
# Leave blank in dev to derive a key from API_SECRET (zero config). Only needed
# if you connect Gmail. Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Hosts are the compose service names. DATABASE_URL uses the psycopg v3 driver,
# so the scheme MUST be postgresql+psycopg:// (plain postgresql:// looks for
# psycopg2, which isn't installed).
DATABASE_URL=postgresql+psycopg://mailbox:mailbox@db:5432/ai_mailbox
REDIS_URL=redis://redis:6379/0

# Browser origins allowed to call the API (CORS). Not exercised in the default
# single-origin setup (nginx proxies /api), but set for anyone hitting :8000
# directly. Never use "*" with credentialed requests.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Email classifier ---
# heuristic | local | gemini | auto.
#   heuristic = keyword rules only, no deps or model (the zero-config default).
#   local     = fine-tuned encoder under CLASSIFIER_MODEL_PATH. Needs torch, so
#               build with INSTALL_LOCAL_CLASSIFIER=true and put the model in
#               ./models/email-classifier. Falls back to heuristic if missing.
#   gemini    = LLM (needs GEMINI_API_KEY), heuristic fallback.
CLASSIFIER_BACKEND=heuristic

# --- LLM / Google OAuth (optional — only for real Gmail ingest) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The SPA handles the callback, so this points at the frontend origin (:8080),
# not the API. Register the same URI in the Google Cloud console OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
