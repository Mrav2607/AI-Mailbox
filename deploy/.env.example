# Copy to .env and fill in real values: cp .env.example .env

# --- Postgres ---
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_mailbox

# --- App ---
APP_ENV=dev
# Signs session tokens (HS256 JWT). Use a long random value in production --
# anyone with it can mint valid logins.
API_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=10080  # 7 days
# Comma-separated browser origins allowed to call the API (CORS). Set the real
# frontend origin(s) in production; do not use "*" with credentialed requests.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Full SQLAlchemy URL. URL-encode special characters in the password
# (e.g. "#" -> "%23", "@" -> "%40"). Host is the compose service name "db".
DATABASE_URL=postgresql+psycopg://changeme:changeme@db:5432/ai_mailbox
REDIS_URL=redis://redis:6379/0

# --- LLM / Google OAuth ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Email classifier ---
# Backend: local | gemini | heuristic | auto.
#   local     = fine-tuned encoder under CLASSIFIER_MODEL_PATH (needs the
#               "local-classifier" extra: pip install -e ".[local-classifier]").
#               Falls back to gemini/heuristic if torch/model are unavailable.
#   gemini    = LLM (needs GEMINI_API_KEY), heuristic fallback.
#   heuristic = keyword rules only, no deps.
CLASSIFIER_BACKEND=local
CLASSIFIER_MODEL_PATH=models/email-classifier
