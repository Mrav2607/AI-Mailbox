# Production template. Copy to deploy/.env, generate every required secret,
# fill in the Google OAuth settings, then run from the repo root:
#   cp deploy/.env.example deploy/.env
#   openssl rand -hex 32                     # API_SECRET
#   openssl rand -hex 32                     # POSTGRES_PASSWORD / REDIS_PASSWORD
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# The stack intentionally refuses to start while the placeholder secrets remain.
# For the zero-config local demo-login flow, use deploy/local.env.example instead.

# --- Postgres ---
# These are read by the db container AND make up DATABASE_URL below -- keep them
# in sync. Avoid special characters here, or URL-encode them in DATABASE_URL
# (e.g. "#" -> "%23", "@" -> "%40").
POSTGRES_USER=mailbox
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ai_mailbox

# --- App ---
# Production disables the passwordless demo login and validates the required
# JWT, token-encryption, and Google OAuth settings at startup.
APP_ENV=production
# Signs session tokens (HS256 JWT). Replace before starting the stack.
API_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=10080  # 7 days
# Encrypts provider OAuth tokens at rest (Fernet, urlsafe base64 32 bytes).
# Production requires a dedicated key. Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Hosts are the compose service names. DATABASE_URL uses the psycopg v3 driver,
# so the scheme MUST be postgresql+psycopg:// (plain postgresql:// looks for
# psycopg2, which isn't installed).
DATABASE_URL=postgresql+psycopg://mailbox:change_me@db:5432/ai_mailbox
# Use the same generated value in both fields. Redis refuses to start with the
# placeholder password.
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@redis:6379/0

# Browser origins allowed to call the API (CORS). Not exercised in the default
# single-origin setup (nginx proxies /api), but set for anyone hitting :8000
# directly. Never use "*" with credentialed requests.
CORS_ORIGINS=https://mail.example.com

# --- Email classifier ---
# heuristic | local | gemini | auto.
#   heuristic = keyword rules only, no deps or model.
#   local     = fine-tuned encoder under CLASSIFIER_MODEL_PATH. Needs torch, so
#               build with INSTALL_LOCAL_CLASSIFIER=true and put the model in
#               ./models/email-classifier. Falls back to heuristic if missing.
#   gemini    = LLM (needs GEMINI_API_KEY), heuristic fallback.
CLASSIFIER_BACKEND=heuristic

# --- LLM / Google OAuth ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The SPA handles the callback, so use its public HTTPS origin, not the API.
# Register the same URI in the Google Cloud console OAuth client.
GOOGLE_REDIRECT_URI=https://mail.example.com/auth/google/callback
