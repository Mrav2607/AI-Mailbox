# Build the SPA, then serve the static bundle with nginx. nginx also reverse-
# proxies /api to the api container, so the whole app lives behind one origin
# (no CORS). Build context is the repo ROOT (see docker-compose.yml).
FROM node:22-alpine AS build
WORKDIR /app

COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci

COPY apps/web/ ./
# Baked in at build time by Vite. A relative base keeps API calls same-origin so
# nginx can proxy them; override via the build arg for a different API host.
ARG VITE_API_BASE_URL=/api/v1
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

# Everything below is what it takes to run nginx as a normal user. The pid file
# defaults to /run, which only root can write, and the `user` directive is both
# meaningless and noisy once the master process isn't root. The temp dirs under
# /var/cache/nginx are where nginx buffers proxied responses, so they have to be
# writable too. (The server block listens on 8080 for the same reason: a non-root
# process can't bind port 80.)
RUN sed -i -e 's|^pid .*|pid /tmp/nginx.pid;|' -e '/^user /d' /etc/nginx/nginx.conf && \
    chown -R nginx:nginx /var/cache/nginx
USER nginx
