# Zero-config local stack. Copy this file to deploy/.env, then run
# `docker compose up --build` from the repo root and open http://localhost:8080.
# The passwordless demo login is available only because APP_ENV is dev.

POSTGRES_USER=mailbox
POSTGRES_PASSWORD=mailbox
POSTGRES_DB=ai_mailbox

APP_ENV=dev
API_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=10080
TOKEN_ENCRYPTION_KEY=

DATABASE_URL=postgresql+psycopg://mailbox:mailbox@db:5432/ai_mailbox
REDIS_PASSWORD=mailbox-local
REDIS_URL=redis://:mailbox-local@redis:6379/0
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

CLASSIFIER_BACKEND=heuristic

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Optional -- Outlook stays hidden until all three are set.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8080/auth/microsoft/callback
MICROSOFT_TENANT=common
OUTLOOK_BACKFILL_DAYS=90
