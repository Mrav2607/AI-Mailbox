# Build context is the repo root (docker-compose.yml). The API image needs
# apps/api/{pyproject.toml,app,alembic,alembic.ini}; the web image runs its own
# `npm ci`, so keep node_modules and the prebuilt bundle out of the context.

# Node build artifacts (the web image installs and builds from source)
**/node_modules/
apps/web/dist/

# Stray local docker artifact
image.tar

# Virtualenvs / Python caches
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/*.egg-info/

# VCS & local secrets (never bake .env into the image)
.git/
.gitignore
**/.env
.env

# Data, training, and tooling not used at serve time
data/
ml/
scripts/
logs/
notebooks/
apps/api/tests/

# Training checkpoints are a full duplicate of the model + optimizer state;
# serving only reads models/email-classifier/{config,tokenizer,model.safetensors,labels.json}
models/*/checkpoints/
